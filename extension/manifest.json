{
  "manifest_version": 3,
  "name": "ShopLens — Shop What You Watch",
  "short_name": "ShopLens",
  "version": "1.0.0",
  "description": "See something you like on YouTube Shorts? Click once — AI finds it on Myntra, Flipkart, and Amazon.in.",
  "permissions": ["storage", "activeTab", "alarms"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://serpapi.com/*",
    "https://0x0.st/*",
    "https://*.modal.run/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/shorts/*"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["overlay.css", "icons/*.png"],
      "matches": ["https://www.youtube.com/*"]
    }
  ]
}
